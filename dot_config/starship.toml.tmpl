# Get editor completions based on the config schema
"$schema" = 'https://starship.rs/config-schema.json'
right_format = "$time"

# Inserts a blank line between shell prompts
add_newline = false

# Replace the 'έζψ' symbol in the prompt with another one
[character] # The name of the module we are configuring is 'character'
success_symbol = '[έΙχ](bold green)' # The 'success_symbol' segment is being set to 'έηε' with the color 'bold green'
error_symbol = '[έΙχ](bold red)'

[username]
show_always = true
style_user = 'bold yellow'
format = '[έΝΑ ]($style bold)[$user]($style) at '

[hostname]
ssh_symbol = "ΌυΒ "
ssh_only = false
style = 'bold white'
{{- if eq .chezmoi.hostname "zeus" }}
format = '[$ssh_symbolΎΔπ $hostname]($style) in '
{{- else if eq .chezmoi.hostname "hades" }}
format = '[$ssh_symbolέβΘ $hostname]($style) in '
{{- else if eq .chezmoi.hostname "hestia" }}
format = '[$ssh_symbolέγ╢ $hostname]($style) in '
{{- else if eq .chezmoi.hostname "hera" }}
format = '[$ssh_symbolέγ╡ $hostname]($style) in '
{{- else }}
format = '[$ssh_symbol $hostname]($style) in '
{{- end }}

[directory]
read_only = " ≤░Ν╛"
truncation_symbol = '.../'
truncation_length = 5
format = '[$path]($style)[$read_only]($read_only_style) '

[line_break]
disabled = false # Disable the line_break module, making the prompt a single line

[time]
disabled = false
format = '[ΎΑΩ $time]($style)'
style = "bright-black"

[cmd_duration]
style = "bright-black"

